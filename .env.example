# Public-facing host port mappings (bound to 127.0.0.1 only; Caddy reverse-proxies from 80/443)
API_PORT=3001
WEB_PORT=5173

# Meilisearch: bind to loopback only. Never set this to "0.0.0.0:7700" — the master key is in this env file.
MEILI_PORT_BIND=127.0.0.1:7700

# Meilisearch
MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=book-id-search-dev-key
MEILI_INDEX=books
MEILI_ENV=development

# Data + index storage (override to a dedicated /data volume for full import)
MEILI_DATA_DIR=./meili_data
BOOK_DATA_DIR=./data

# Frontend build arg (baked at build time into the SPA bundle)
VITE_API_BASE_URL=/api

# --- AI-assisted book search (optional, S21A) ---
# All MiniMax vars must be set AND AI_FEATURES_ENABLED=true to activate
# the /api/ai/search-intent endpoint and the "AI 找书" tab in the UI.
# Leave AI_FEATURES_ENABLED=false (default) to disable the feature entirely.
#
# Token Plan subscription keys are NOT interchangeable with pay-as-you-go API keys.
# Use MINIMAX_WIRE_API=responses for Token Plan /v1/responses (default),
#                       anthropic for Token Plan /anthropic/messages,
#                       openai_chat for /v1/chat/completions.
AI_FEATURES_ENABLED=false
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
MINIMAX_WIRE_API=responses