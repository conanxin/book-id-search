# Public-facing host port mappings (bound to 127.0.0.1 only; Caddy reverse-proxies from 80/443)
API_PORT=3001
WEB_PORT=5173

# Meilisearch: bind to loopback only. Never set this to "0.0.0.0:7700" — the master key is in this env file.
MEILI_PORT_BIND=127.0.0.1:7700

# Meilisearch
MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=book-id-search-dev-key
MEILI_INDEX=books
MEILI_ENV=development

# Data + index storage (override to a dedicated /data volume for full import)
MEILI_DATA_DIR=./meili_data
BOOK_DATA_DIR=./data

# Frontend build arg (baked at build time into the SPA bundle)
VITE_API_BASE_URL=/api